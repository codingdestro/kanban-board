{
  "name": "@kanban/desktop",
  "version": "0.1.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "prebuild": "rm -rf out && cp -r ../web/out ./out",
    "build": "electron-builder",
    "pack": "electron-builder --dir",
    "lint": "eslint ."
  },
  "dependencies": {
    "@kanban/types": "workspace:*"
  },
  "devDependencies": {
    "@kanban/eslint-config": "workspace:*",
    "@kanban/tsconfig": "workspace:*",
    "@kanban/web": "workspace:*",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.kanban.devflow",
    "productName": "DevFlow Kanban",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "out/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": ["dmg"]
    },
    "win": {
      "target": ["nsis"]
    },
    "linux": {
      "target": ["AppImage"]
    }
  }
}
